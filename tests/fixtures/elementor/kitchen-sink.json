[
  {
    "id": "sec_hero",
    "elType": "section",
    "settings": {
      "layout": "boxed",
      "background_color": "#0f172a",
      "padding": {"unit": "px", "top": "80", "right": "0", "bottom": "80", "left": "0"}
    },
    "elements": [
      {
        "id": "col_hero",
        "elType": "column",
        "settings": {"_column_size": 100},
        "elements": [
          {
            "id": "w_h1",
            "elType": "widget",
            "widgetType": "heading",
            "settings": {"title": "Kitchen Sink Hero", "header_size": "h1", "align": "center", "title_color": "#ffffff"}
          },
          {
            "id": "w_p1",
            "elType": "widget",
            "widgetType": "text-editor",
            "settings": {"editor": "<p>Everything below was previously dropped or collapsed.</p>", "align": "center"}
          },
          {
            "id": "w_btn1",
            "elType": "widget",
            "widgetType": "button",
            "settings": {"text": "Get started", "link": {"url": "https://example.com/start", "is_external": true, "nofollow": true}}
          },
          {"id": "w_div1", "elType": "widget", "widgetType": "divider", "settings": {}}
        ]
      }
    ]
  },
  {
    "id": "sec_features",
    "elType": "section",
    "settings": {},
    "elements": [
      {
        "id": "col_a",
        "elType": "column",
        "settings": {"_column_size": 33.33},
        "elements": [
          {
            "id": "w_iconbox",
            "elType": "widget",
            "widgetType": "icon-box",
            "settings": {
              "title_text": "Fast",
              "description_text": "Edge-cached responses in milliseconds.",
              "link": {"url": "https://example.com/perf"},
              "button_text": "Read more",
              "image": {"url": "https://example.com/icons/fast.png", "alt": "Speed icon"}
            }
          }
        ]
      },
      {
        "id": "col_b",
        "elType": "column",
        "settings": {"_column_size": 33.33},
        "elements": [
          {
            "id": "w_iconlist",
            "elType": "widget",
            "widgetType": "icon-list",
            "settings": {
              "icon_list": [
                {"text": "Zero downtime deploys"},
                {"text": "Per-tenant isolation"},
                {"text": "Audit log retention 365 days"}
              ]
            }
          }
        ]
      },
      {
        "id": "col_c",
        "elType": "column",
        "settings": {"_column_size": 33.34},
        "elements": [
          {
            "id": "w_counter",
            "elType": "widget",
            "widgetType": "counter",
            "settings": {"ending_number": 99, "prefix": "", "suffix": ".9%", "title": "Uptime SLA"}
          }
        ]
      }
    ]
  },
  {
    "id": "sec_compound",
    "elType": "section",
    "settings": {},
    "elements": [
      {
        "id": "col_compound",
        "elType": "column",
        "settings": {"_column_size": 100},
        "elements": [
          {
            "id": "w_tabs",
            "elType": "widget",
            "widgetType": "tabs",
            "settings": {
              "tabs": [
                {"tab_title": "Overview", "tab_content": "<p>Tab one body.</p>"},
                {"tab_title": "Pricing", "tab_content": "<p>Tab two body.</p>"},
                {"tab_title": "FAQ", "tab_content": "<p>Tab three body.</p>"}
              ]
            }
          },
          {
            "id": "w_accordion",
            "elType": "widget",
            "widgetType": "accordion",
            "settings": {
              "tabs": [
                {"tab_title": "What is the SLA?", "tab_content": "99.9% with sub-second recovery."},
                {"tab_title": "Can I cancel anytime?", "tab_content": "Yes, monthly billing."}
              ]
            }
          },
          {
            "id": "w_cta",
            "elType": "widget",
            "widgetType": "call-to-action",
            "settings": {
              "title": "Ready to ship?",
              "description": "Sign up in seconds.",
              "button_text": "Create account",
              "link": {"url": "https://example.com/signup"}
            }
          },
          {
            "id": "w_pricing",
            "elType": "widget",
            "widgetType": "price-table",
            "settings": {
              "heading": "Pro",
              "currency_symbol": "$",
              "price": "49",
              "period": "mo",
              "features": [
                {"item_text": "Unlimited projects"},
                {"item_text": "Priority support"},
                {"item_text": "Audit logs"}
              ],
              "button_text": "Subscribe",
              "button_url": "https://example.com/subscribe"
            }
          },
          {
            "id": "w_testimonial",
            "elType": "widget",
            "widgetType": "testimonial",
            "settings": {
              "testimonial_content": "We cut migration time by 80%.",
              "testimonial_name": "Jane Doe",
              "testimonial_job": "CTO, Acme"
            }
          },
          {
            "id": "w_alert",
            "elType": "widget",
            "widgetType": "alert",
            "settings": {
              "alert_type": "success",
              "alert_title": "Migrations complete",
              "alert_description": "All 142 pages converted."
            }
          }
        ]
      }
    ]
  },
