{
    "name": "coryhubbell/development-translation-bridge",
    "description": "Universal WordPress page builder translation system with AI optimization",
    "type": "wordpress-theme",
    "version": "4.10.0",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Cory Hubbell",
            "email": "cory@example.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "brain/monkey": "^2.7",
        "mockery/mockery": "^1.6",
        "php-stubs/wordpress-stubs": "^7.0",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "classmap": [
            "includes/",
            "translation-bridge/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "scripts": {
        "test": "phpunit --no-coverage",
        "test:coverage": "phpunit --coverage-html coverage",
        "test:watch": "phpunit --watch"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.1.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
